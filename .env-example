# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Provider selection ────────────────────────────────────────────────────────
# Which LLM provider to use: "anthropic" or "gemini"
# Overrides the provider.active field in config/setup.json
LLM_PROVIDER=gemini

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required only when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Required only when LLM_PROVIDER=gemini
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Tavily web search (optional) ──────────────────────────────────────────────
# Used by debater agents for citation retrieval
TAVILY_API_KEY=your_tavily_api_key_here

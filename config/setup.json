{
  "version": "1.00",
  "debate": {
    "default_rounds": 10,
    "language": "en",
    "timeout_seconds": 120,
    "max_search_queries_per_turn": 3,
    "anti_sycophancy_phrases": [
      "good point", "i agree", "that's correct", "you're right",
      "fair point", "well said", "i concede", "you make a valid point"
    ]
  },
  "provider": {
    "active": "gemini",
    "anthropic": {
      "debater_model": "claude-sonnet-4-6",
      "judge_model": "claude-sonnet-4-6",
      "temperature": 0.7,
      "max_tokens": 1024
    },
    "gemini": {
      "debater_model": "gemini-2.5-flash-lite",
      "judge_model": "gemini-2.5-flash-lite",
      "temperature": 0.7,
      "max_tokens": 1024
    }
  },
  "agents": {
    "judge_model": "claude-sonnet-4-6",
    "debater_model": "claude-sonnet-4-6",
    "temperature": 0.7,
    "max_tokens": 1024
  },
  "costs": {
    "claude-sonnet-4-6": {
      "input_per_million_tokens": 3.0,
      "output_per_million_tokens": 15.0
    },
    "gemini-2.0-flash": {
      "input_per_million_tokens": 0.075,
      "output_per_million_tokens": 0.30
    }
  },
  "sdk": {
    "results_dir": "results/",
    "assets_dir": "assets/"
  }
}
